<script>
(function(){
  try {
    var win = window;
    var hostWindow = win.top && win.top.location ? win.top : win;
    var desiredTab = <?=!empty($cfg['first']) ? json_encode('tab2') : json_encode('tab1')?>;
    var currentTab = String((document.cookie.match(/(?:^|;\s*)one=([^;]+)/) || [])[1] || '');
    var guardKey = 'statsview.tab-sync:' + desiredTab;

    document.cookie = 'one=' + desiredTab + '; path=/';

    if (desiredTab !== 'tab1' && win.sessionStorage && !win.sessionStorage.getItem(guardKey)) {
      win.sessionStorage.setItem(guardKey, '1');
      var syncUrl = new URL(hostWindow.location.href);
      syncUrl.searchParams.set('svplustab', desiredTab);
      syncUrl.searchParams.set('svplusr', String(Date.now()));
      hostWindow.location.replace(syncUrl.toString());
      return;
    }

    if (win.sessionStorage && currentTab === desiredTab) {
      win.sessionStorage.removeItem(guardKey);
    }
  } catch (_statsviewTabSyncError) {}
})();
</script>
<script>
(function(){
  try {
    var win = window;
    var hostWindow = win.top && win.top.location ? win.top : win;
    if (!win || !win.sessionStorage) return;
    var currentVersion = <?=json_encode($page_version, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE)?>;
    var pageKey = 'statsview-plus-disk-stats';
    var path = String((win.location && win.location.pathname) || pageKey);
    var storageKey = 'statsview.page-version:' + pageKey + ':' + path;
    var reloadKey = storageKey + ':reloaded';
    var previousVersion = String(win.sessionStorage.getItem(storageKey) || '').trim();
    var lastReloadedVersion = String(win.sessionStorage.getItem(reloadKey) || '').trim();
    win.sessionStorage.setItem(storageKey, currentVersion);
    if (previousVersion && previousVersion !== currentVersion && lastReloadedVersion !== currentVersion) {
      win.sessionStorage.setItem(reloadKey, currentVersion);
      var url = new URL(hostWindow.location.href);
      url.searchParams.set('svplusv', currentVersion);
      url.searchParams.set('svplusr', String(Date.now()));
      hostWindow.location.replace(url.toString());
      return;
    }
    if (previousVersion === currentVersion && lastReloadedVersion === currentVersion) {
      win.sessionStorage.removeItem(reloadKey);
    }
  } catch (_statsviewVersionError) {}
})();
</script>
<script>
(function(){
  try {
    var win = window;
    var doc = document;
    var pluginName = <?=json_encode($plugin, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE)?>;
    var currentVersion = <?=json_encode($page_version, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE)?>;
    var endpoint = <?=json_encode("/plugins/$plugin/include/HardwareStats.php", JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE)?>;
    var latestVersion = currentVersion;

    function assetUrl(relativePath, version) {
      return '/plugins/' + pluginName + '/' + relativePath.replace(/^\/+/, '') + '?v=' + encodeURIComponent(version);
    }

    try {
      var request = new XMLHttpRequest();
      request.open('POST', endpoint, false);
      request.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded; charset=UTF-8');
      request.send('cmd=plugin_version');
      if (request.status >= 200 && request.status < 300) {
        var payload = JSON.parse(request.responseText || '{}');
        latestVersion = String(payload.pluginVersion || '').trim() || currentVersion;
      }
    } catch (_statsviewVersionProbeError) {}

    if (win.statsViewDiskDashboardConfig) {
      win.statsViewDiskDashboardConfig.assetVersion = latestVersion;
    }

    var stylesheet = doc.getElementById('svplus-disk-stylesheet');
    if (stylesheet) {
      stylesheet.href = assetUrl('sheets/SystemDisks.css', latestVersion);
    }

    var script = doc.createElement('script');
    script.src = assetUrl('javascript/system-disks-dashboard.js', latestVersion);
    doc.body.appendChild(script);
  } catch (_statsviewDiskAssetLoadError) {}
})();
</script>

