<script>
window.statsViewSystemDashboardBoot = (function(win, doc) {
  var timeoutId = null;

  function getRoot() {
    return doc.getElementById('svplus-system-dashboard');
  }

  function getBanner() {
    return doc.getElementById('svplus-system-error');
  }

  function appendLine(parent, className, text) {
    var node = doc.createElement(className === 'svplus-system-banner-detail' ? 'pre' : 'strong');
    node.className = className;
    node.textContent = text;
    parent.appendChild(node);
  }

  function normalizeError(error) {
    var parts = [];
    if (!error) {
      return parts;
    }
    if (typeof error === 'string') {
      parts.push(error);
      return parts;
    }
    if (error.name && error.message) {
      parts.push(error.name + ': ' + error.message);
    } else if (error.message) {
      parts.push(String(error.message));
    }
    if (error.filename) {
      parts.push('Source: ' + error.filename);
    }
    if (error.line || error.lineno) {
      parts.push('Line: ' + String(error.line || error.lineno));
    }
    if (error.column || error.colno) {
      parts.push('Column: ' + String(error.column || error.colno));
    }
    if (!parts.length) {
      parts.push(String(error));
    }
    return parts;
  }

  function showFailure(message, error) {
    var root = getRoot();
    var banner = getBanner();
    var details = normalizeError(error);

    if (timeoutId) {
      win.clearTimeout(timeoutId);
      timeoutId = null;
    }

    if (root) {
      root.classList.add('is-ready');
      root.classList.remove('is-loading');
    }

    if (!banner) {
      return;
    }

    banner.hidden = false;
    banner.textContent = '';
    appendLine(banner, 'svplus-system-banner-title', message);
    if (details.length) {
      appendLine(banner, 'svplus-system-banner-detail', details.join('\n'));
    }
  }

  var api = {
    initialized: false,
    fail: function(message, error) {
      showFailure(message, error);
      if (win.console && typeof win.console.error === 'function') {
        win.console.error('StatsView Plus System Stats failure:', message, error || '');
      }
    },
    succeed: function() {
      api.initialized = true;
      if (timeoutId) {
        win.clearTimeout(timeoutId);
        timeoutId = null;
      }
    }
  };

  win.addEventListener('error', function(event) {
    var file = String(event && event.filename || '');
    var message = String(event && event.message || '');
    if (file.indexOf('system-stats-dashboard') !== -1 || file.indexOf('jquery.highcharts') !== -1 || message.indexOf('Highcharts') !== -1 || message.indexOf('jQuery') !== -1 || message.indexOf('$') !== -1) {
      api.fail('System Stats failed while loading frontend assets.', event.error || {
        message: message,
        filename: file,
        lineno: event && event.lineno,
        colno: event && event.colno
      });
    }
  });

  win.addEventListener('unhandledrejection', function(event) {
    api.fail('System Stats failed because a browser promise was rejected.', event && event.reason);
  });

  timeoutId = win.setTimeout(function() {
    if (!api.initialized) {
      api.fail('System Stats did not finish initializing.', {
        message: 'The dashboard bootstrap did not report success. A script may have failed before rendering the page.'
      });
    }
  }, 4000);

  return api;
})(window, document);
</script>
<script>
(function(){
  try {
    var win = window;
    var hostWindow = win.top && win.top.location ? win.top : win;
    var desiredTab = <?=!empty($cfg['first']) ? json_encode('tab2') : json_encode('tab1')?>;
    var currentTab = String((document.cookie.match(/(?:^|;\s*)one=([^;]+)/) || [])[1] || '');
    var guardKey = 'statsview.tab-sync:' + desiredTab;

    document.cookie = 'one=' + desiredTab + '; path=/';

    if (desiredTab !== 'tab2' && win.sessionStorage && !win.sessionStorage.getItem(guardKey)) {
      win.sessionStorage.setItem(guardKey, '1');
      var syncUrl = new URL(hostWindow.location.href);
      syncUrl.searchParams.set('svplustab', desiredTab);
      syncUrl.searchParams.set('svplusr', String(Date.now()));
      hostWindow.location.replace(syncUrl.toString());
      return;
    }

    if (win.sessionStorage && currentTab === desiredTab) {
      win.sessionStorage.removeItem(guardKey);
    }
  } catch (_statsviewTabSyncError) {}
})();
</script>
<script>
(function(){
  try {
    var win = window;
    var hostWindow = win.top && win.top.location ? win.top : win;
    if (!win || !win.sessionStorage) return;
    var currentVersion = <?=json_encode($page_version, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE)?>;
    var pageKey = 'statsview-plus-system-stats';
    var path = String((win.location && win.location.pathname) || pageKey);
    var storageKey = 'statsview.page-version:' + pageKey + ':' + path;
    var reloadKey = storageKey + ':reloaded';
    var previousVersion = String(win.sessionStorage.getItem(storageKey) || '').trim();
    var lastReloadedVersion = String(win.sessionStorage.getItem(reloadKey) || '').trim();
    win.sessionStorage.setItem(storageKey, currentVersion);
    if (previousVersion && previousVersion !== currentVersion && lastReloadedVersion !== currentVersion) {
      win.sessionStorage.setItem(reloadKey, currentVersion);
      var url = new URL(hostWindow.location.href);
      url.searchParams.set('svplusv', currentVersion);
      url.searchParams.set('svplusr', String(Date.now()));
      hostWindow.location.replace(url.toString());
      return;
    }
    if (previousVersion === currentVersion && lastReloadedVersion === currentVersion) {
      win.sessionStorage.removeItem(reloadKey);
    }
  } catch (_statsviewVersionError) {}
})();
</script>
<script>
(function(){
  try {
    var win = window;
    var doc = document;
    var pluginName = <?=json_encode($plugin, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE)?>;
    var currentVersion = <?=json_encode($page_version, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE)?>;
    var endpoint = <?=json_encode("/plugins/$plugin/include/HardwareStats.php", JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE)?>;
    var latestVersion = currentVersion;

    function assetUrl(relativePath, version) {
      return '/plugins/' + pluginName + '/' + relativePath.replace(/^\/+/, '') + '?v=' + encodeURIComponent(version);
    }

    function loadScript(src, errorMessage, onload) {
      var script = doc.createElement('script');
      script.src = src;
      script.async = false;
      script.onerror = function() {
        if (win.statsViewSystemDashboardBoot && typeof win.statsViewSystemDashboardBoot.fail === 'function') {
          win.statsViewSystemDashboardBoot.fail(errorMessage, { message: src });
        }
      };
      if (typeof onload === 'function') {
        script.onload = onload;
      }
      doc.body.appendChild(script);
    }

    try {
      var request = new XMLHttpRequest();
      request.open('POST', endpoint, false);
      request.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded; charset=UTF-8');
      request.send('cmd=plugin_version');
      if (request.status >= 200 && request.status < 300) {
        var payload = JSON.parse(request.responseText || '{}');
        latestVersion = String(payload.pluginVersion || '').trim() || currentVersion;
      }
    } catch (_statsviewVersionProbeError) {}

    if (win.statsViewSystemDashboardConfig) {
      win.statsViewSystemDashboardConfig.assetVersion = latestVersion;
    }

    var stylesheet = doc.getElementById('svplus-system-stylesheet');
    if (stylesheet) {
      stylesheet.href = assetUrl('sheets/SystemStats.css', latestVersion);
    }

    loadScript(assetUrl('javascript/jquery.highcharts.js', latestVersion), 'Failed to load the System Stats Highcharts library.', function() {
      loadScript(assetUrl('javascript/system-stats-dashboard.js', latestVersion), 'Failed to load the System Stats dashboard script.');
    });
  } catch (_statsviewAssetLoadError) {
    if (window.statsViewSystemDashboardBoot && typeof window.statsViewSystemDashboardBoot.fail === 'function') {
      window.statsViewSystemDashboardBoot.fail('Failed to bootstrap current System Stats assets.', _statsviewAssetLoadError);
    }
  }
})();
</script>

