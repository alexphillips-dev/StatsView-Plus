$plugin = 'statsview.plus';

if (!function_exists('statsview_plus_page_installed_version')) {
  function statsview_plus_page_installed_version($plugin_name) {
    $version_file = "/boot/config/plugins/$plugin_name/version";
    $manifest_file = "/boot/config/plugins/$plugin_name/$plugin_name.plg";
    $version = trim((string)@file_get_contents($version_file));
    if ($version === '' && is_file($manifest_file)) {
      $manifest = (string)@file_get_contents($manifest_file);
      if (preg_match('/<!ENTITY\s+version\s+"([^"]+)"/', $manifest, $matches)) {
        $version = trim((string)$matches[1]);
      }
    }
    return $version === '' ? '0' : $version;
  }
}

$page_version = statsview_plus_page_installed_version($plugin);

if (!headers_sent()) {
  header('Cache-Control: no-store, no-cache, must-revalidate, max-age=0');
  header('Pragma: no-cache');
  header('Expires: 0');
}
?>
<meta http-equiv="Cache-Control" content="no-store, no-cache, must-revalidate, max-age=0">
<meta http-equiv="Pragma" content="no-cache">
<meta http-equiv="Expires" content="0">
<script>
(function(){
  try {
    var win = window;
    if (!win || !win.sessionStorage) return;
    var currentVersion = <?=json_encode($page_version, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE)?>;
    var endpoint = <?=json_encode("/plugins/$plugin/include/HardwareStats.php", JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE)?>;
    var pageKey = 'statsview-plus-root';
    var path = String((win.location && win.location.pathname) || pageKey);
    var storageKey = 'statsview.page-version:' + pageKey + ':' + path;
    var reloadKey = storageKey + ':reloaded';
    var previousVersion = String(win.sessionStorage.getItem(storageKey) || '').trim();
    var lastReloadedVersion = String(win.sessionStorage.getItem(reloadKey) || '').trim();

    win.sessionStorage.setItem(storageKey, currentVersion);
    if (previousVersion && previousVersion !== currentVersion && lastReloadedVersion !== currentVersion) {
      win.sessionStorage.setItem(reloadKey, currentVersion);
      var versionUrl = new URL(win.location.href);
      versionUrl.searchParams.set('svplusv', currentVersion);
      versionUrl.searchParams.set('svplusr', String(Date.now()));
      win.location.replace(versionUrl.toString());
      return;
    }
    if (previousVersion === currentVersion && lastReloadedVersion === currentVersion) {
      win.sessionStorage.removeItem(reloadKey);
    }

    var request = new XMLHttpRequest();
    request.open('POST', endpoint, false);
    request.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded; charset=UTF-8');
    request.send('cmd=plugin_version');
    if (request.status >= 200 && request.status < 300) {
      var payload = JSON.parse(request.responseText || '{}');
      var latestVersion = String(payload.pluginVersion || '').trim();
      if (latestVersion && latestVersion !== currentVersion) {
        var latestUrl = new URL(win.location.href);
        latestUrl.searchParams.set('svplusv', latestVersion);
        latestUrl.searchParams.set('svplusr', String(Date.now()));
        win.location.replace(latestUrl.toString());
      }
    }
  } catch (_statsviewRootVersionError) {}
})();
</script>
