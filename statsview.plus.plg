  <!--
StatsView Plus - disk and system usage graphs
-->
  <!-- PRE-INSTALL SCRIPT -->

<FILE Run="/bin/bash">
<INLINE>
# Remove legacy cron entry (if existing)
crontab -l|sed '/^# System data collection/d;/\/usr\/lib\/sa\/sa1/d'|crontab -

# Remove old 'source' packages
rm -f $(ls /boot/config/plugins/&name;/&name;*.txz 2>/dev/null | grep -v '&version;')
</INLINE>
</FILE>

<!-- SOURCE PACKAGE -->
<FILE Name="/boot/config/plugins/&name;/&name;-&version;-x86_64-1.txz" Run="upgradepkg --install-new --reinstall">
<URL>https://raw.githubusercontent.com/&github;/dev/archive/&name;-&version;-x86_64-1.txz</URL>
<MD5>&MD5;</MD5>
</FILE>

<!-- SYSSTAT PACKAGE (bundled for legacy Unraid support) -->
<FILE Name="/boot/config/plugins/&name;/sysstat-12.7.5.txz" Run="upgradepkg --install-new" Max="6.11.9">
<URL>https://raw.githubusercontent.com/unraid/dynamix/master/archive/sysstat-12.7.5.txz</URL>
</FILE>

<!-- POST-INSTALL SCRIPT -->
<FILE Run="/bin/bash">
<INLINE>
# Create sa directory
OLD=/var/log/sa
NEW=/var/sa
TMP=/tmp/sa

mkdir -p $NEW
chmod 755 $NEW

# Convert legacy files
if [[ -d $OLD ]]; then
  for sa in $OLD/sa* ; do
    /usr/bin/sadf -c $sa &gt;$NEW/$(basename $sa) 2&gt;/dev/null
  done
  rm -rf $OLD
elif [[ $(ls -A $NEW|wc -l) -gt 0 ]]; then
  mkdir -p $TMP
  for sa in $NEW/sa* ; do
    /usr/bin/sadf -c $sa &gt;$TMP/$(basename $sa) 2&gt;/dev/null
  done
  mv -f $TMP/sa* $NEW
  rm -rf $TMP
fi

# Create cron entry
cron=/boot/config/plugins/&name;/sysstats.cron
if [[ ! -f $cron ]]; then
  echo '# Generated system data collection schedule:' &gt;$cron
  echo -e '*/1 * * * * /usr/local/emhttp/plugins/&name;/scripts/sa1 1 1 &amp;&gt; /dev/null\n' &gt;&gt;$cron
fi

# Update cron entries
/usr/local/sbin/update_cron

# Record the installed version so pages can force a one-time refresh after updates
echo "&version;" > /boot/config/plugins/&name;/version

echo ""
echo "-----------------------------------------------------------"
echo " Plugin &name; is installed."
echo " This plugin requires Dynamix webGui to operate"
echo " Version: &version;"
echo "-----------------------------------------------------------"
echo ""
</INLINE>
</FILE>

<!-- REMOVE SCRIPT -->
<FILE Run="/bin/bash" Method="remove">
<INLINE>
# Remove plugin related files
rm -rf /boot/config/plugins/&name;

# Uninstall the 'source' package
removepkg &name;-&version;-x86_64-1 || true

# Remove cron entry
/usr/local/sbin/update_cron
</INLINE>
</FILE>
</PLUGIN>
